# ── Terminal 3 testnet ─────────────────────────────────────────────────────
# Developer API key from https://www.terminal3.io/claim-page (shown once).
# This is the TENANT (data-owner) identity — it signs auth and owns the maps.
T3N_API_KEY=paste-your-key-here

# The Butler agent's OWN identity (a separate ETH key + DID). Generated by
# `npm run agent:setup`; do not set by hand. The tenant delegates scoped
# access to AGENT_DID via `npm run grant`.
# AGENT_T3N_KEY=                 (auto-written by npm run agent:setup)
# AGENT_DID=                     (auto-written by npm run agent:setup)

# ── Mock billing API ───────────────────────────────────────────────────────
# Bearer secret the enclave injects when calling the billing API. The agent
# never sees it — it is seeded into the enclave KV map by `npm run deploy`.
BILLING_API_SECRET=replace-with-a-long-random-string

# Stored "card on file" token. Must match tok_<8-64 alphanumerics>. Seeded
# into the enclave KV map; the enclave injects it on a charge. Never sent by
# the agent or the chat input.
BILLING_CARD_TOKEN=tok_demo4242424242

# Local port for the mock billing server.
BILLING_PORT=8787

# PUBLIC, enclave-reachable URL of the billing API (a tunnel — NOT localhost).
# The T3N enclave makes the outbound call, so it must resolve this from the
# public internet. Set after starting a tunnel (e.g. ngrok/cloudflared) and
# re-run `npm run deploy` + `npm run grant` whenever it changes.
BILLING_PUBLIC_URL=https://your-tunnel-host.example

# ── Chat brain ─────────────────────────────────────────────────────────────
# Which LLM drives the conversational layer (`npm run chat`); the
# contract/ops flow works without any of this.
#   anthropic (default) — Claude Opus 4.8; the most reliable tool calling.
#   ollama              — a local model; nothing leaves your machine.
LLM_PROVIDER=anthropic

# anthropic: API key (only read when LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=

# ollama: only read when LLM_PROVIDER=ollama. OLLAMA_MODEL must be a
# tool-calling-capable model tag from `ollama list`.
# OLLAMA_MODEL=gemma4
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT_MS=120000

# ── Web UI (`npm run web`) ─────────────────────────────────────────────────
# Binds to 127.0.0.1 ONLY — the UI has no auth of its own; do not expose it.
# WEB_PORT=8788
# How long an approve/deny may stay unanswered before it auto-DENIES (ms).
# CONFIRM_TIMEOUT_MS=300000
